# Fast path: run `bun run setup` to create a local .env automatically.
# Preferred manual option: keep confidential OAuth credentials in environment variables.
YOUTUBE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
YOUTUBE_OAUTH_CLIENT_SECRET=your-client-secret

# Alternative: store the downloaded Desktop app OAuth JSON in base64 form.
# YOUTUBE_OAUTH_CLIENT_JSON_BASE64=eyJpbnN0YWxsZWQiOns...

# Optional: override where the refreshed OAuth token is stored locally.
# YT_PLAYLIST_DEDUPE_CONFIG_DIR=/absolute/path/to/config-dir

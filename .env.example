# Advanced overrides for local development.
# Most users should run `yt-ddp setup`, which stores normalized OAuth client
# config in the app config directory instead of the project workspace.
YT_DDP_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
YT_DDP_OAUTH_CLIENT_SECRET=your-client-secret

# Alternative: store the downloaded Desktop app OAuth JSON in base64 form.
# YT_DDP_OAUTH_CLIENT_JSON_BASE64=eyJpbnN0YWxsZWQiOns...

# Optional: override where the refreshed OAuth token is stored locally.
# YT_DDP_CONFIG_DIR=/absolute/path/to/config-dir

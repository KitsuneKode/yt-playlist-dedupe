{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!-next/cache/**"]
    },
    "lint": {
      "dependsOn": []
    },
    "format": {
      "dependsOn": []
    },
    "test": {
      "dependsOn": []
    },
    "check": {
      "dependsOn": ["lint", "test"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}

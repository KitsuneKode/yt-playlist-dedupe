{
  "name": "@kitsunekode/yt-ddp",
  "version": "0.2.0",
  "description": "CLI for safely finding and removing duplicate videos from a YouTube playlist.",
  "keywords": [
    "cli",
    "dedupe",
    "npm",
    "playlist",
    "youtube"
  ],
  "homepage": "https://github.com/KitsuneKode/yt-playlist-dedupe#readme",
  "bugs": {
    "url": "https://github.com/KitsuneKode/yt-playlist-dedupe/issues"
  },
  "license": "MIT",
  "author": "KitsuneKode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KitsuneKode/yt-playlist-dedupe.git"
  },
  "bin": {
    "yt-ddp": "dist/index.js"
  },
  "files": [
    "dist",
    "completions",
    "docs"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "setup": "bun run src/index.ts setup",
    "clean": "bun --eval 'await Bun.$`rm -rf dist`'",
    "build": "bun run clean && bun build src/index.ts --target=node --packages=external --outfile=dist/index.js && bun --eval 'await Bun.$`chmod 755 dist/index.js`'",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "check": "bun run lint && bun run typecheck && bun run test",
    "smoke:built": "bun dist/index.js --help",
    "pack:dry-run": "bun pm pack --dry-run",
    "link:global": "bun run build && bun link",
    "unlink:global": "bun unlink",
    "publish:check": "bun run check && bun run build && bun run smoke:built && bun run pack:dry-run",
    "release": "bun run publish:check && bun publish --access public",
    "prepublishOnly": "bun run publish:check"
  },
  "dependencies": {
    "@yt-ddp/core": "workspace:*",
    "googleapis": "^171.4.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "typescript": "latest"
  },
  "engines": {
    "bun": ">=1.3.9",
    "node": ">=18"
  },
  "packageManager": "bun@1.3.9"
}
